rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/events/{eventId}/{allPaths=**} {
      // Public event sharing intentionally exposes the original source files while enabled.
      allow read: if (request.auth != null && request.auth.uid == userId) || resource.metadata.privacy == 'public';
      allow write: if false;
    }

    match /users/{userId}/{allPaths=**} {
      // Client apps can read their own stored originals, but uploads/writes are backend-only.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
