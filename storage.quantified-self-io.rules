rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/events/{eventId}/{allPaths=**} {
      function isPublicParentEvent() {
        return firestore.exists(/databases/(default)/documents/users/$(userId)/events/$(eventId))
          && firestore.get(/databases/(default)/documents/users/$(userId)/events/$(eventId)).data.privacy == 'public';
      }

      // Event folders store original source files only. Public event sharing intentionally exposes
      // known object paths under the shared event folder while the parent event is public.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow get: if isPublicParentEvent();
      allow write: if false;
    }

    match /users/{userId}/{allPaths=**} {
      // Client apps can read their own stored originals, but uploads/writes are backend-only.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
