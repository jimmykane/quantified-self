  "functions": {
    "predeploy": [],
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    {
      "target": "production",
      "rules": "storage.quantified-self-io.rules"
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8081
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  },
  "extensions": {
    "delete-user-data": "firebase/delete-user-data@0.1.27",
    "firestore-send-email": "firebase/firestore-send-email@0.2.6",
    "firestore-stripe-payments": "invertase/firestore-stripe-payments@0.3.12"
  },
  "remoteconfig": {
    "template": "remoteconfig.json"
  }
