{{> email_transactional_header}}
<h1 style="margin:0 0 20px; color:#172033; font-size:26px; line-height:34px;">You’re now on {{new_role}}</h1>

<p style="margin:0 0 18px;">Your membership has changed from <strong>{{old_role}}</strong> → <strong>{{new_role}}</strong>.</p>
<p style="margin:0 0 20px;">Thank you for supporting Quantified Self.</p>

{{#if plan_details_available}}
<p style="margin:0 0 10px; font-weight:700; color:#172033;">Your new plan includes</p>
<ul style="margin:0 0 24px; padding-left:22px;">
  <li style="margin:0 0 7px;">{{activity_description}}</li>
  <li style="margin:0 0 7px;">{{route_description}}</li>
  <li style="margin:0 0 7px;">{{ai_insights_description}}</li>
  {{#if device_sync_description}}<li style="margin:0 0 7px;">{{device_sync_description}}</li>{{/if}}
</ul>
{{/if}}

<table role="presentation" class="email-button" cellspacing="0" cellpadding="0" border="0">
  <tr>
    <td style="border-radius:6px; background-color:#174ea6;">
      <a href="{{dashboard_url}}" style="display:inline-block; min-height:44px; padding:12px 22px; box-sizing:border-box; color:#ffffff; font-weight:700; text-decoration:none;">Open dashboard</a>
    </td>
  </tr>
</table>
{{> email_transactional_footer}}
