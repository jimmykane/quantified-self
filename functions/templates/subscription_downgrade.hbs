{{> email_transactional_header}}
<h1 style="margin:0 0 20px; color:#172033; font-size:26px; line-height:34px;">Your membership is now {{new_role}}</h1>

<p style="margin:0 0 18px;">This confirms your change from <strong>{{old_role}}</strong> → <strong>{{new_role}}</strong>.</p>
<p style="margin:0 0 18px;">Your existing activities and routes remain in Quantified Self. Future uploads use the limits of your {{new_role}} plan.</p>

{{#if plan_details_available}}
<ul style="margin:0 0 22px; padding-left:22px;">
  <li style="margin:0 0 7px;">{{activity_description}}</li>
  <li style="margin:0 0 7px;">{{route_description}}</li>
  <li style="margin:0 0 7px;">{{ai_insights_description}}</li>
  {{#if device_sync_description}}<li style="margin:0 0 7px;">{{device_sync_description}}</li>{{/if}}
</ul>
{{/if}}

{{#if device_sync_will_end}}
<p style="margin:0 0 22px; padding:14px 16px; background-color:#fff5d6; border-left:4px solid #9a6700; color:#513c06;">Device sync is not included in {{new_role}}. Your grace-period details and connection status are available in Quantified Self.</p>
{{/if}}

<table role="presentation" class="email-button" cellspacing="0" cellpadding="0" border="0">
  <tr>
    <td style="border-radius:6px; background-color:#174ea6;">
      <a href="{{membership_url}}" style="display:inline-block; min-height:44px; padding:12px 22px; box-sizing:border-box; color:#ffffff; font-weight:700; text-decoration:none;">Manage membership</a>
    </td>
  </tr>
</table>
{{> email_transactional_footer}}
